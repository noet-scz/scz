{
  "name": "scz",
  "version": "0.1.0",
  "description": "SCZ — Самоуправляемая Цифровая Зона. Клиент на Tauri v2.",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "build:linux": "tauri build --bundles appimage,deb,rpm",
    "build:windows": "tauri build --bundles nsis,msi",
    "android:init": "tauri android init",
    "build:android:apk": "tauri android build --apk --debug"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
