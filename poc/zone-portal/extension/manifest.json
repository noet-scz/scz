{
  "manifest_version": 3,
  "name": "noet — зона .nt",
  "version": "0.3.0",
  "description": "Открывает имена зоны *.nt прямо в адресной строке браузера (поиск, зала, сайты). Клик по иконке — вкл/выкл.",
  "permissions": ["proxy", "storage"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "noet — зона .nt (клик: вкл/выкл)",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
